# ══════════════════════════════════════════════════════════════
# BOT (Express) — local: .env | produccion: variables en Railway
# ══════════════════════════════════════════════════════════════

# Anthropic (requerido)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-5

# Supabase — si se omiten, el bot corre en modo DEMO con datos en memoria
# Settings → API: Project URL y service_role key (secreta, solo backend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# WhatsApp Cloud API (Meta) — fallback single-tenant; en multi-tenant van en la tabla organizations
# WHATSAPP_TOKEN: token permanente del usuario del sistema (Business Suite)
# WHATSAPP_PHONE_ID: identificador del numero (Diamond: 1218037454725710)
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_TOKEN=EAAxxxxxxx
VERIFY_TOKEN=tu_token_secreto

# API interna para el CRM (proteje POST /api/send y toma de control)
BOT_API_KEY=una_clave_larga_aleatoria

# Telegram (canal de pruebas/demo, opcional)
TELEGRAM_TOKEN=123456:ABC-DEF...

# Servidor (Railway lo asigna solo via PORT)
PORT=3003

# ══════════════════════════════════════════════════════════════
# CRM (Next.js en crm/) — variables en Vercel (o crm/.env.local)
# ══════════════════════════════════════════════════════════════
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co        (misma Project URL)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                     (anon/public key)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...                         (service_role, solo server)
# BOT_API_URL=https://tu-bot.up.railway.app                (URL del bot en Railway)
# BOT_API_KEY=una_clave_larga_aleatoria                    (la misma del bot)
