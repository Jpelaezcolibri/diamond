# Servidor
PORT=3010
NODE_ENV=development
LOG_LEVEL=info

# Autenticacion API (compartida con el proxy del CRM)
DMAP_API_KEY=

# Cifrado de tokens en reposo (32 bytes en base64 -> `openssl rand -base64 32`)
DMAP_ENCRYPTION_KEY=

# Redis (BullMQ) — addon de Railway
REDIS_URL=redis://localhost:6379

# Supabase (misma instancia que el bot y el CRM)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# IA
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# Meta (la MISMA Meta App que ya usa WhatsApp/Sofi)
META_APP_ID=
META_APP_SECRET=

# URLs publicas
DMAP_PUBLIC_URL=http://localhost:3010
CRM_URL=http://localhost:3000
