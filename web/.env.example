# Tenant activo (clave del registro en config/tenants/index.ts)
TENANT_ID=diamond

# Supabase (misma instancia que el bot y el CRM).
# Sin estas variables la web corre en modo DEMO con inventario de muestra.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor — para escribir leads desde /api/leads. NUNCA exponer con NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# Org de Supabase cuyo inventario se muestra (uuid de organizations.id).
# Si se omite, no se filtra por organizacion (valido cuando la BD tiene una sola org).
TENANT_ORG_ID=

# Meta Ads — ambos vacios = tracking apagado (no-op).
# Pixel ID: Events Manager > Origenes de datos > (tu pixel) > ID del conjunto de datos.
NEXT_PUBLIC_META_PIXEL_ID=
# Token de CAPI: Events Manager > Configuracion > Conversions API > Generar token.
# SOLO servidor — NUNCA exponer con NEXT_PUBLIC.
META_CAPI_ACCESS_TOKEN=
